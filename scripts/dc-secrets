#!/usr/bin/env bash
# dc-secrets: credential store using SOPS (age backend) with flock concurrency.
# Single source of truth for all credentials. SOPS files are git-committable
# (keys visible, values encrypted). Designed for multi-agent Docker environments.
set -euo pipefail

SECRETS_DIR="${DC_SECRETS_DIR:-$(cd "$(dirname "$0")/.." && pwd)/secrets}"
IDENTITY_FILE="$SECRETS_DIR/.age-identity"
SOPS_CONFIG="$SECRETS_DIR/.sops.yaml"
LOCKS_DIR="$SECRETS_DIR/.locks"
export SOPS_AGE_KEY_FILE="$IDENTITY_FILE"

die() { echo "dc-secrets: error: $*" >&2; exit 1; }

require_sops() {
    command -v sops >/dev/null 2>&1 || die "sops not found. Install: https://github.com/getsops/sops"
    command -v age >/dev/null 2>&1 || die "age not found. Install: https://github.com/FiloSottile/age"
}

require_init() {
    [[ -f "$IDENTITY_FILE" ]] || die "not initialized. Run: dc-secrets init"
    [[ -f "$SOPS_CONFIG" ]] || die ".sops.yaml missing. Run: dc-secrets init"
}

# Resolve logical path (e.g. "shared/api") to SOPS YAML file
resolve_path() {
    echo "$SECRETS_DIR/${1}.yaml"
}

resolve_lock() {
    local logical="$1"
    local lock_dir="$LOCKS_DIR/$(dirname "$logical")"
    mkdir -p "$lock_dir"
    echo "$lock_dir/$(basename "$logical").lock"
}

# Decrypt a SOPS file, output flat key=value lines (no YAML nesting)
decrypt_flat() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    sops -d "$file" 2>/dev/null | yaml_to_flat
}

# Convert flat YAML (key: value) to key=value, skipping sops metadata
yaml_to_flat() {
    while IFS= read -r line; do
        # Skip blank, comments, sops metadata block
        [[ -z "$line" || "$line" == "#"* || "$line" == "sops:"* ]] && continue
        [[ "$line" == "    "* ]] && continue  # sops metadata indented lines
        # Parse "key: value" → "key=value"
        local key="${line%%:*}"
        local rest="${line#*: }"
        # Handle quoted strings
        rest="${rest#\"}" ; rest="${rest%\"}"
        rest="${rest#\'}" ; rest="${rest%\'}"
        echo "${key}=${rest}"
    done
}

# Create/update a SOPS-encrypted YAML file from key=value pairs on stdin
encrypt_yaml() {
    local file="$1"
    local tmp
    tmp="$(mktemp --suffix=.yaml)"
    mkdir -p "$(dirname "$file")"
    cat > "$tmp"
    sops -e -i --config "$SOPS_CONFIG" "$tmp" 2>/dev/null
    mv "$tmp" "$file"
}

# Build YAML content from key=value lines
flat_to_yaml() {
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local key="${line%%=*}"
        local value="${line#*=}"
        # Escape backslashes and double quotes for valid YAML
        value="${value//\\/\\\\}"
        value="${value//\"/\\\"}"
        printf '%s: "%s"\n' "$key" "$value"
    done
}

# ─── Commands ──────────────────────────────────────────────────────────────────

cmd_init() {
    require_sops
    mkdir -p "$SECRETS_DIR/shared" "$SECRETS_DIR/agents" "$LOCKS_DIR"

    if [[ -f "$IDENTITY_FILE" ]]; then
        local pubkey
        pubkey=$(grep '^# public key:' "$IDENTITY_FILE" | sed 's/^# public key: //')
        echo "Already initialized."
        echo "Recipient: $pubkey"
        # Ensure .sops.yaml exists
        if [[ ! -f "$SOPS_CONFIG" ]]; then
            cat > "$SOPS_CONFIG" <<YAML
creation_rules:
  - path_regex: \\.yaml\$
    age: $pubkey
YAML
            echo "Created $SOPS_CONFIG"
        fi
        return 0
    fi

    local stderr_output
    stderr_output=$(age-keygen -o "$IDENTITY_FILE" 2>&1)
    chmod 600 "$IDENTITY_FILE"

    local pubkey
    pubkey=$(echo "$stderr_output" | sed -n 's/^Public key: //p')
    [[ -n "$pubkey" ]] || die "failed to extract public key from age-keygen"

    cat > "$SOPS_CONFIG" <<YAML
creation_rules:
  - path_regex: \\.yaml\$
    age: $pubkey
YAML

    echo "Initialized secrets store at $SECRETS_DIR"
    echo "Identity: $IDENTITY_FILE (KEEP SECRET — do NOT commit)"
    echo "Recipient: $pubkey"
    echo "SOPS config: $SOPS_CONFIG (commit this)"
}

cmd_get() {
    [[ $# -ge 2 ]] || die "usage: dc-secrets get <path> <key>"
    require_sops; require_init
    local file key
    file=$(resolve_path "$1"); key="$2"
    [[ -f "$file" ]] || die "secret file not found: $1"

    local value
    value=$(sops -d --extract "[\"$key\"]" "$file" 2>/dev/null) || die "key not found: $key in $1"
    echo "$value"
}

cmd_set() {
    [[ $# -ge 2 ]] || die "usage: dc-secrets set <path> <key>=<value>"
    require_sops; require_init
    local logical="$1"; shift
    local file lock_file
    file=$(resolve_path "$logical")
    lock_file=$(resolve_lock "$logical")

    (
        flock -w 10 200 || die "could not acquire lock for $logical (timeout 10s)"

        # Decrypt existing content or start fresh
        local content=""
        if [[ -f "$file" ]]; then
            content=$(decrypt_flat "$file") || content=""
        fi

        for kv in "$@"; do
            local key="${kv%%=*}"
            local value="${kv#*=}"
            [[ "$kv" == *=* ]] || die "invalid format: $kv (expected key=value)"

            # Remove existing key, then append
            local new_content=""
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                local k="${line%%=*}"
                [[ "$k" == "$key" ]] && continue
                new_content+="$line"$'\n'
            done <<< "$content"
            content="${new_content}${key}=${value}"$'\n'
        done

        echo -n "$content" | flat_to_yaml | encrypt_yaml "$file"

    ) 200>"$lock_file"
}

cmd_delete() {
    [[ $# -ge 2 ]] || die "usage: dc-secrets delete <path> <key>"
    require_sops; require_init
    local logical="$1"; local key="$2"
    local file lock_file
    file=$(resolve_path "$logical")
    lock_file=$(resolve_lock "$logical")
    [[ -f "$file" ]] || die "secret file not found: $logical"

    (
        flock -w 10 200 || die "could not acquire lock for $logical (timeout 10s)"

        local content found=false new_content=""
        content=$(decrypt_flat "$file")
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local k="${line%%=*}"
            if [[ "$k" == "$key" ]]; then
                found=true; continue
            fi
            new_content+="$line"$'\n'
        done <<< "$content"

        [[ "$found" == true ]] || die "key not found: $key in $logical"

        if [[ -z "$new_content" ]]; then
            rm -f "$file"
        else
            echo -n "$new_content" | flat_to_yaml | encrypt_yaml "$file"
        fi

    ) 200>"$lock_file"
}

cmd_export() {
    require_sops; require_init
    local agent=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent) agent="$2"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    # Shared secrets first
    for f in "$SECRETS_DIR"/shared/*.yaml; do
        [[ -f "$f" ]] || continue
        decrypt_flat "$f"
    done

    # Agent-specific overrides
    if [[ -n "$agent" ]]; then
        local agent_file="$SECRETS_DIR/agents/${agent}.yaml"
        if [[ -f "$agent_file" ]]; then
            decrypt_flat "$agent_file"
        fi
    fi
}

cmd_list() {
    require_init
    if [[ $# -eq 0 ]]; then
        find "$SECRETS_DIR" -name '*.yaml' -not -name '.sops.yaml' -printf '%P\n' | sed 's/\.yaml$//' | sort
    else
        require_sops
        local file
        file=$(resolve_path "$1")
        [[ -f "$file" ]] || die "secret file not found: $1"
        # List keys from SOPS file (encrypted keys are visible without decryption)
        sops -d "$file" 2>/dev/null | yaml_to_flat | while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            echo "${line%%=*}"
        done
    fi
}

cmd_import() {
    [[ $# -ge 2 ]] || die "usage: dc-secrets import <env-file> <path>"
    require_sops; require_init
    local env_file="$1" logical="$2"
    [[ -f "$env_file" ]] || die "file not found: $env_file"

    local file lock_file
    file=$(resolve_path "$logical")
    lock_file=$(resolve_lock "$logical")

    # Parse env file outside subshell so we can report count
    local content=""
    while IFS= read -r line; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        line="${line#export }"
        [[ "$line" == *=* ]] || continue
        # Strip surrounding quotes from value
        local key="${line%%=*}"
        local value="${line#*=}"
        value="${value#\"}" ; value="${value%\"}"
        value="${value#\'}" ; value="${value%\'}"
        content+="${key}=${value}"$'\n'
    done < "$env_file"

    [[ -n "$content" ]] || die "no key=value pairs found in $env_file"

    (
        flock -w 10 200 || die "could not acquire lock for $logical (timeout 10s)"
        echo -n "$content" | flat_to_yaml | encrypt_yaml "$file"
    ) 200>"$lock_file"

    local count
    count=$(echo -n "$content" | grep -c '=')
    echo "Imported $count keys into $logical"
}

cmd_edit() {
    [[ $# -ge 1 ]] || die "usage: dc-secrets edit <path>"
    require_sops; require_init
    local file
    file=$(resolve_path "$1")
    [[ -f "$file" ]] || die "secret file not found: $1 (create it first with 'set' or 'import')"
    sops "$file"
}

cmd_help() {
    cat <<'EOF'
dc-secrets: credential store using SOPS (age encryption)

USAGE:
    dc-secrets <command> [args...]

COMMANDS:
    init                          Initialize store (generate age keypair + .sops.yaml)
    get    <path> <key>           Read a single credential
    set    <path> <key>=<value>   Write one or more credentials (flock-protected)
    delete <path> <key>           Remove a credential
    export [--agent <name>]       Print all shared (+ agent-specific) creds as key=value
    list   [<path>]               List secret files, or keys within a file
    import <env-file> <path>      Import a .env file into encrypted storage
    edit   <path>                 Open in $EDITOR via sops (decrypt, edit, re-encrypt)
    help                          Show this help

PATHS:
    shared/<name>       Shared credentials (all agents)
    agents/<name>       Per-agent credentials

FILES:
    secrets/.sops.yaml      SOPS config (commit to git)
    secrets/.age-identity   Private key (NEVER commit — add to .gitignore)
    secrets/shared/*.yaml   SOPS-encrypted shared creds (commit to git)
    secrets/agents/*.yaml   SOPS-encrypted per-agent creds (commit to git)

ENVIRONMENT:
    DC_SECRETS_DIR          Override secrets directory (default: <repo>/secrets)
    SOPS_AGE_KEY_FILE       Override age identity file

EXAMPLES:
    dc-secrets init
    dc-secrets set shared/cloudflare CF_API_TOKEN=xxx CF_ZONE_ID=yyy
    dc-secrets get shared/cloudflare CF_API_TOKEN
    dc-secrets edit shared/cloudflare
    dc-secrets export --agent agent-1
    dc-secrets import api/.env shared/api
    dc-secrets list
    dc-secrets list shared/cloudflare
EOF
}

# ─── Main ──────────────────────────────────────────────────────────────────────

[[ $# -ge 1 ]] || { cmd_help; exit 1; }
command="$1"; shift
case "$command" in
    init)   cmd_init "$@" ;;
    get)    cmd_get "$@" ;;
    set)    cmd_set "$@" ;;
    delete) cmd_delete "$@" ;;
    export) cmd_export "$@" ;;
    list)   cmd_list "$@" ;;
    import) cmd_import "$@" ;;
    edit)   cmd_edit "$@" ;;
    help|--help|-h) cmd_help ;;
    *)      die "unknown command: $command. Run 'dc-secrets help'" ;;
esac
