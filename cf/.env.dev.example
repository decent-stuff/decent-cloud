# Local development environment for scripts/dev-server.sh.
# Copy to cf/.env.dev and edit. (cf/.env.dev is gitignored.)
#
# This file is sourced with `set -a; source cf/.env.dev` by dev-server.sh, so
# every var here is exported into the env of both the API server and the
# website dev server.
#
# The Postgres sidecar in this workspace is reachable at hostname `postgres`
# (DATABASE_URL=postgres://test:test@postgres:5432/test).

# --- required by dev-server.sh ------------------------------------------------
# Used as DATABASE_URL when launching target/debug/api-server.
API_DATABASE_URL=postgres://test:test@postgres:5432/test

# --- consumed by api-server if present ----------------------------------------
ENVIRONMENT=dev
API_PUBLIC_URL=http://localhost:59011
FRONTEND_URL=http://localhost:59010

# CANISTER_ID defaults to ggi4a-wyaaa-aaaai-actqq-cai (IC mainnet) when unset.
# Override only if you need a different canister.
#CANISTER_ID=ggi4a-wyaaa-aaaai-actqq-cai

# --- optional integrations (leave commented to run with warnings) -------------
# Stripe (test keys from https://dashboard.stripe.com/apikeys)
#STRIPE_SECRET_KEY=sk_test_...
#STRIPE_PUBLISHABLE_KEY=pk_test_...
#STRIPE_WEBHOOK_SECRET=whsec_test_secret

# Chatwoot (live chat widget)
#CHATWOOT_BASE_URL=https://app.chatwoot.com
#CHATWOOT_API_TOKEN=...
#CHATWOOT_WEBSITE_TOKEN=...

# Email (MailChannels)
#MAILCHANNELS_API_KEY=...
#DKIM_SELECTOR=selector1
#DKIM_PRIVATE_KEY=...
#DKIM_DOMAIN=example.com

# At-rest encryption for stored credentials (32 bytes hex). Generate with:
#   openssl rand -hex 32
#CREDENTIAL_ENCRYPTION_KEY=...
