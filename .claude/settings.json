{
  "mcpServers": {
    "browser": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--cdp-endpoint",
        "http://192.168.0.13:9223",
        "--vision"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/limit-tool-calls.sh"
          }
        ]
      }
    ]
  }
}
